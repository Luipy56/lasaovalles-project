{
  "name": "saovalles",
  "version": "1.0.0",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "ng": "ng",
    "start": "concurrently -k -n api,web -c cyan,magenta \"npm run dev --prefix api\" \"ng serve\"",
    "dev": "npm start",
    "start:web": "ng serve",
    "start:api": "npm run start --prefix api",
    "postinstall": "npm install --prefix api",
    "dev:api": "npm run dev --prefix api",
    "dev:web": "npm run start:web",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@10.9.3",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ngneat/transloco": "^6.0.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
