PORT=3000
# Comma-separated origins for browser CORS (Angular dev server or production site URL)
CORS_ORIGIN=http://localhost:4200

# Default catalog file (repo includes api/data/order-catalog.json)
CATALOG_PATH=

# Gmail: use an App Password with 2-Step Verification, not your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=youraccount@gmail.com
SMTP_PASS=your-app-password

MAIL_FROM=La Saó <youraccount@gmail.com>
OWNER_EMAIL=lasao.valles@gmail.com

# Long random string; same value used in /admin/catalogo in the browser
ADMIN_API_TOKEN=change-me-to-a-long-random-secret

# Optional: max POST /orders per IP per window (see express-rate-limit defaults in server)
# ORDER_RATE_MAX=30
